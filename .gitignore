```gitignore
# Compiled and build artifacts
*.pyc
__pycache__/
*.o
*.obj
dist/
build/
*.js.map

# Dependencies
.venv/
venv/
node_modules/
.pip-cache/
.mypy_cache/
.pytest_cache/

# Logs and temp files
*.log
*.tmp
*.swp
*.swo

# Environment
.env
.env.local
.env.*

# Editors
.vscode/
.idea/
*.swp
*.swo

# OS specific
.DS_Store
Thumbs.db

# Coverage reports
coverage/
htmlcov/
.coverage

# Compressed files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
```
